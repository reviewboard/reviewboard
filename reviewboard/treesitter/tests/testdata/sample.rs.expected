<span class="ts-keyword-import">use</span> <span class="ts-variable"><span class="ts-module">std</span></span>::<span class="ts-variable"><span class="ts-module">collections</span></span>::<span class="ts-variable">HashMap</span>;
<span class="ts-keyword-import">use</span> <span class="ts-variable"><span class="ts-module">std</span></span>::<span class="ts-variable"><span class="ts-module">fmt</span></span>::<span class="ts-variable">Display</span>;

<span class="ts-comment">//<span class="ts-operator"><span class="ts-comment">/</span></span> Documentation comment for Person struct</span>
<span class="ts-comment"></span>#[<span class="ts-function"><span class="ts-variable">derive</span></span>(<span class="ts-variable">Debug</span>, <span class="ts-variable">Clone</span>)]
<span class="ts-keyword">pub</span> <span class="ts-keyword">struct</span> Person {
