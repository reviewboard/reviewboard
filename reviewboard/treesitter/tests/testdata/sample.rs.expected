        <span class="ts-function"><span class="ts-variable">format</span></span><span class="ts-function"><span class="ts-operator">!</span></span>(<span class="ts-string">&quot;Hello, my name is {}&quot;</span>, <span class="ts-variable-builtin">self</span>.<span class="ts-variable">name</span>)
    }
}

<span class="ts-keyword">impl</span> Person {
    <span class="ts-comment">//<span class="ts-operator"><span class="ts-comment">/</span></span> Creates a new Person</span>
<span class="ts-comment"></span>    <span class="ts-keyword">pub</span> <span class="ts-keyword">fn</span> <span class="ts-function"><span class="ts-variable">new</span></span>(<span class="ts-variable">name</span>: String, <span class="ts-variable">age</span>: <span class="ts-type-builtin">u32</span>) -&gt; Self {
