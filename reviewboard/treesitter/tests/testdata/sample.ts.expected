    <span class="ts-variable-builtin">this</span>.<span class="ts-variable">userStore</span>.<span class="ts-function-method-call"><span class="ts-variable">on</span></span>(<span class="ts-string">&#39;itemAdded&#39;</span>, (<span class="ts-variable">user</span>) <span class="ts-operator">=&gt;</span> {
