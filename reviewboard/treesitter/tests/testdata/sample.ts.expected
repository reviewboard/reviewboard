    <span class="ts-variable-builtin">this</span>.<span class="ts-variable">items</span>.<span class="ts-function-method-call"><span class="ts-variable">set</span></span>(<span class="ts-variable">id</span>, <span class="ts-variable">updatedItem</span>);
