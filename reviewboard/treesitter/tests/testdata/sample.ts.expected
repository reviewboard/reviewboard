  <span class="ts-keyword">private</span> <span class="ts-keyword">async</span> <span class="ts-function"><span class="ts-variable">validateUser</span></span>(<span class="ts-variable">user</span>: User): Promise<span class="ts-operator">&lt;</span><span class="ts-type-builtin">void</span><span class="ts-operator">&gt;</span> {
    <span class="ts-keyword">return</span> <span class="ts-keyword">new</span> <span class="ts-type-builtin"><span class="ts-constructor"><span class="ts-variable">Promise</span></span></span>((<span class="ts-variable">resolve</span>, <span class="ts-variable">reject</span>) <span class="ts-operator">=&gt;</span> {
      <span class="ts-function-call"><span class="ts-variable">setTimeout</span></span>(() <span class="ts-operator">=&gt;</span> {
        <span class="ts-keyword">if</span> (<span class="ts-operator">!</span><span class="ts-variable">user</span>.<span class="ts-variable">name</span>.<span class="ts-function-method-call"><span class="ts-variable">trim</span></span>()) {
          <span class="ts-function-call"><span class="ts-variable">reject</span></span>(<span class="ts-keyword">new</span> <span class="ts-type-builtin"><span class="ts-constructor"><span class="ts-variable">Error</span></span></span>(<span class="ts-string">&#39;Name is required&#39;</span>));
        } <span class="ts-keyword">else</span> <span class="ts-keyword">if</span> (<span class="ts-variable">user</span>.<span class="ts-variable">email</span> <span class="ts-operator">&amp;&amp;</span> <span class="ts-operator">!</span><span class="ts-variable-builtin">this</span>.<span class="ts-function-method-call"><span class="ts-variable">isValidEmail</span></span>(<span class="ts-variable">user</span>.<span class="ts-variable">email</span>)) {
          <span class="ts-function-call"><span class="ts-variable">reject</span></span>(<span class="ts-keyword">new</span> <span class="ts-type-builtin"><span class="ts-constructor"><span class="ts-variable">Error</span></span></span>(<span class="ts-string">&#39;Invalid email format&#39;</span>));
        } <span class="ts-keyword">else</span> {
          <span class="ts-function-call"><span class="ts-variable">resolve</span></span>();
        }
      }, <span class="ts-number">100</span>);
    });
  }

  <span class="ts-keyword">private</span> <span class="ts-function"><span class="ts-variable">isValidEmail</span></span>(<span class="ts-variable">email</span>: <span class="ts-type-builtin">string</span>): <span class="ts-type-builtin">boolean</span> {
    <span class="ts-keyword">const</span> <span class="ts-variable">emailRegex</span> <span class="ts-operator">=</span> /<span class="ts-string-regexp">^[^\s@]+@[^\s@]+\.[^\s@]+$</span>/;
    <span class="ts-keyword">return</span> <span class="ts-variable">emailRegex</span>.<span class="ts-function-method-call"><span class="ts-variable">test</span></span>(<span class="ts-variable">email</span>);
  }

  <span class="ts-function"><span class="ts-variable">getUsersByRole</span></span>(<span class="ts-variable">role</span>: Role): User[] {
