  <span class="ts-keyword">async</span> <span class="ts-function"><span class="ts-variable">createUser</span></span>(<span class="ts-variable">name</span>: <span class="ts-type-builtin">string</span>, <span class="ts-variable">email</span>?: <span class="ts-type-builtin">string</span>, <span class="ts-variable">roles</span>: Role[] <span class="ts-operator">=</span> [<span class="ts-string">&#39;user&#39;</span>]): Promise<span class="ts-operator">&lt;</span>ApiResponse<span class="ts-operator">&lt;</span>User<span class="ts-operator">&gt;</span><span class="ts-operator">&gt;</span> {
    <span class="ts-keyword">try</span> {
      <span class="ts-keyword">const</span> <span class="ts-variable">user</span>: User <span class="ts-operator">=</span> {
        <span class="ts-variable">id</span>: <span class="ts-type-builtin"><span class="ts-variable">Date</span></span>.<span class="ts-function-method-call"><span class="ts-variable">now</span></span>(), <span class="ts-comment">// Simple ID generation</span>
        <span class="ts-variable">name</span>,
        <span class="ts-variable">email</span>,
        <span class="ts-variable">roles</span>,
      };

      <span class="ts-comment">// Simulate async validation</span>
      <span class="ts-keyword">await</span> <span class="ts-variable-builtin">this</span>.<span class="ts-function-method-call"><span class="ts-variable">validateUser</span></span>(<span class="ts-variable">user</span>);

      <span class="ts-variable-builtin">this</span>.<span class="ts-variable">userStore</span>.<span class="ts-function-method-call"><span class="ts-variable">add</span></span>(<span class="ts-variable">user</span>);

      <span class="ts-keyword">return</span> {
        <span class="ts-variable">data</span>: <span class="ts-variable">user</span>,
        <span class="ts-variable">status</span>: <span class="ts-string">&#39;success&#39;</span>,
        <span class="ts-variable">message</span>: <span class="ts-string">&#39;User created successfully&#39;</span>,
      };
    } <span class="ts-keyword">catch</span> (<span class="ts-variable">error</span>) {
      <span class="ts-keyword">return</span> {
        <span class="ts-variable">data</span>: {} <span class="ts-keyword"><span class="ts-keyword-import">as</span></span> User,
        <span class="ts-variable">status</span>: <span class="ts-string">&#39;error&#39;</span>,
        <span class="ts-variable">message</span>: <span class="ts-variable">error</span> <span class="ts-keyword">instanceof</span> <span class="ts-type-builtin"><span class="ts-variable">Error</span></span> <span class="ts-keyword">?</span> <span class="ts-variable">error</span>.<span class="ts-variable">message</span> <span class="ts-keyword">:</span> <span class="ts-string">&#39;Unknown error&#39;</span>,
      };
    }
