<span class="ts-comment">// User service with async operations</span>
<span class="ts-keyword">class</span> UserService {
  <span class="ts-keyword">private</span> <span class="ts-variable">userStore</span> <span class="ts-operator">=</span> <span class="ts-keyword">new</span> <span class="ts-constructor"><span class="ts-variable">DataStore</span></span><span class="ts-operator">&lt;</span>User<span class="ts-operator">&gt;</span>(<span class="ts-string">&#39;users&#39;</span>);
  <span class="ts-keyword">private</span> <span class="ts-keyword">static</span> <span class="ts-variable">instance</span>: UserService;

