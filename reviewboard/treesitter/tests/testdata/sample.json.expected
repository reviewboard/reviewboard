      <span class="ts-string">&quot;eslint:recommended&quot;</span>,
      <span class="ts-string">&quot;@typescript-eslint/recommended&quot;</span>
    ],
    &quot;rules&quot;: {
      &quot;no-console&quot;: <span class="ts-string">&quot;warn&quot;</span>,
