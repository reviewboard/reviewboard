    }
  },
  &quot;metadata&quot;: {
    &quot;buildNumber&quot;: <span class="ts-number">12345</span>,
    &quot;buildDate&quot;: <span class="ts-string">&quot;2023-12-01T10:30:00Z&quot;</span>,
    &quot;gitCommit&quot;: <span class="ts-string">&quot;a1b2c3d4e5f6&quot;</span>,
