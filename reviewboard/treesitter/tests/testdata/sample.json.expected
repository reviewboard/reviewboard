      }
    },
    &quot;localization&quot;: {
      &quot;supportedLanguages&quot;: [<span class="ts-string">&quot;en&quot;</span>, <span class="ts-string">&quot;es&quot;</span>, <span class="ts-string">&quot;fr&quot;</span>, <span class="ts-string">&quot;de&quot;</span>, <span class="ts-string">&quot;ja&quot;</span>],
      &quot;defaultLanguage&quot;: <span class="ts-string">&quot;en&quot;</span>,
      &quot;fallbackLanguage&quot;: <span class="ts-string">&quot;en&quot;</span>
    }
  }
