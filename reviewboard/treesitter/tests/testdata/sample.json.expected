  &quot;browserslist&quot;: [
    <span class="ts-string">&quot;&gt; 1%&quot;</span>,
    <span class="ts-string">&quot;last 2 versions&quot;</span>,
    <span class="ts-string">&quot;not dead&quot;</span>,
    <span class="ts-string">&quot;not ie 11&quot;</span>
  ],
  &quot;jest&quot;: {
    &quot;testEnvironment&quot;: <span class="ts-string">&quot;node&quot;</span>,
    &quot;collectCoverage&quot;: <span class="ts-boolean">true</span>,
    &quot;coverageDirectory&quot;: <span class="ts-string">&quot;coverage&quot;</span>,
    &quot;testMatch&quot;: [
      <span class="ts-string">&quot;**/__tests__/**/*.test.js&quot;</span>
    ]
  },
  &quot;eslintConfig&quot;: {
