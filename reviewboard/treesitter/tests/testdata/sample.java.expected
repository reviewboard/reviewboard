    <span class="ts-comment">// Main method for testing</span>
    <span class="ts-keyword">public</span> <span class="ts-keyword">static</span> <span class="ts-type-builtin">void</span> <span class="ts-function"><span class="ts-variable">main</span></span>(String[] <span class="ts-variable">args</span>) {
