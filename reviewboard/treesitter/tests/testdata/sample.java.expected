            List<span class="ts-operator">&lt;</span>User<span class="ts-operator">&gt;</span> <span class="ts-variable">admins</span> <span class="ts-operator">=</span> <span class="ts-variable">manager</span>.<span class="ts-function-method-call"><span class="ts-variable">findUsers</span></span>(<span class="ts-variable">user</span> <span class="ts-operator">-&gt;</span> <span class="ts-string">&quot;ADMIN&quot;</span>.<span class="ts-function-method-call"><span class="ts-variable">equals</span></span>(<span class="ts-variable">user</span>.<span class="ts-function-method-call"><span class="ts-variable">getRole</span></span>()));
            <span class="ts-variable">System</span>.<span class="ts-variable">out</span>.<span class="ts-function-method-call"><span class="ts-variable">println</span></span>(<span class="ts-string">&quot;<span class="ts-string">\n</span>Admin users: &quot;</span> <span class="ts-operator">+</span> <span class="ts-variable">admins</span>);

            <span class="ts-comment">// Get role statistics</span>
            Map<span class="ts-operator">&lt;</span>String, Long<span class="ts-operator">&gt;</span> <span class="ts-variable">stats</span> <span class="ts-operator">=</span> <span class="ts-variable">manager</span>.<span class="ts-function-method-call"><span class="ts-variable">getRoleStatistics</span></span>();
            <span class="ts-variable">System</span>.<span class="ts-variable">out</span>.<span class="ts-function-method-call"><span class="ts-variable">println</span></span>(<span class="ts-string">&quot;<span class="ts-string">\n</span>Role statistics: &quot;</span> <span class="ts-operator">+</span> <span class="ts-variable">stats</span>);

