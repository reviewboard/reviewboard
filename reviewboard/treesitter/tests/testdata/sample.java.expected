            User <span class="ts-variable">bob</span> <span class="ts-operator">=</span> <span class="ts-variable">manager</span>.<span class="ts-function-method-call"><span class="ts-variable">createUser</span></span>(<span class="ts-string">&quot;Bob Smith&quot;</span>, <span class="ts-string">&quot;bob@test.com&quot;</span>, <span class="ts-constant-builtin">null</span>);
            User <span class="ts-variable">carol</span> <span class="ts-operator">=</span> <span class="ts-variable">manager</span>.<span class="ts-function-method-call"><span class="ts-variable">createUser</span></span>(<span class="ts-string">&quot;Carol Davis&quot;</span>, <span class="ts-string">&quot;carol@company.org&quot;</span>, <span class="ts-string">&quot;MODERATOR&quot;</span>);

            <span class="ts-variable">System</span>.<span class="ts-variable">out</span>.<span class="ts-function-method-call"><span class="ts-variable">println</span></span>(<span class="ts-string">&quot;Created users:&quot;</span>);
            <span class="ts-variable">manager</span>.<span class="ts-function-method-call"><span class="ts-variable">processUsers</span></span>();

