    <span class="ts-comment">// Enum example</span>
    <span class="ts-keyword">public</span> <span class="ts-keyword">enum</span> <span class="ts-variable">UserStatus</span> {
        <span class="ts-constant"><span class="ts-variable">ACTIVE</span></span>(<span class="ts-string">&quot;Active&quot;</span>),
        <span class="ts-constant"><span class="ts-variable">INACTIVE</span></span>(<span class="ts-string">&quot;Inactive&quot;</span>),
        <span class="ts-constant"><span class="ts-variable">SUSPENDED</span></span>(<span class="ts-string">&quot;Suspended&quot;</span>),
