                <span class="ts-variable">user</span>.<span class="ts-function-method-call"><span class="ts-variable">getId</span></span>(),
                <span class="ts-variable">newName</span> <span class="ts-operator">!=</span> <span class="ts-constant-builtin">null</span> <span class="ts-keyword">?</span> <span class="ts-variable">newName</span>.<span class="ts-function-method-call"><span class="ts-variable">trim</span></span>() <span class="ts-keyword"><span class="ts-operator">:</span></span> <span class="ts-variable">user</span>.<span class="ts-function-method-call"><span class="ts-variable">getName</span></span>(),
                <span class="ts-variable">newEmail</span> <span class="ts-operator">!=</span> <span class="ts-constant-builtin">null</span> <span class="ts-keyword">?</span> <span class="ts-variable">newEmail</span>.<span class="ts-function-method-call"><span class="ts-variable">toLowerCase</span></span>() <span class="ts-keyword"><span class="ts-operator">:</span></span> <span class="ts-variable">user</span>.<span class="ts-function-method-call"><span class="ts-variable">getEmail</span></span>(),
