<span class="ts-comment">     * @throws IllegalArgumentException if validation fails</span>
<span class="ts-comment">     */</span>
    <span class="ts-keyword">public</span> User <span class="ts-function"><span class="ts-variable">createUser</span></span>(String <span class="ts-variable">name</span>, String <span class="ts-variable">email</span>, String <span class="ts-variable">role</span>)
