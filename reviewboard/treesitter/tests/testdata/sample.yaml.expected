<span class="ts-comment"># YAML Configuration Example</span>
<span class="ts-comment"># Demonstrating various YAML features and syntax</span>

<span class="ts-comment"># Application configuration</span>
<span class="ts-string">app</span>:
  <span class="ts-string">name</span>: <span class="ts-string">&quot;ReviewBoard Example&quot;</span>
  <span class="ts-string">version</span>: <span class="ts-string">&quot;1.0.0&quot;</span>
  <span class="ts-string">description</span>: <span class="ts-string">|</span>
<span class="ts-string">    A comprehensive YAML example file demonstrating</span>
<span class="ts-string">    various YAML features including:</span>
<span class="ts-string">    - Scalars, sequences, and mappings</span>
<span class="ts-string">    - Multi-line strings</span>
<span class="ts-string">    - Anchors and aliases</span>
<span class="ts-string">    - Different data types</span>

  <span class="ts-comment"># Environment settings</span>
  <span class="ts-string">environment</span>: &amp;default_env
    <span class="ts-string">debug</span>: <span class="ts-boolean">true</span>
    <span class="ts-string">logging_level</span>: <span class="ts-string">&quot;info&quot;</span>
    <span class="ts-string">max_connections</span>: <span class="ts-number">100</span>
    <span class="ts-string">timeout</span>: <span class="ts-number">30</span>

  <span class="ts-comment"># Database configuration with anchor</span>
  <span class="ts-string">database</span>: &amp;db_config
    <span class="ts-string">host</span>: <span class="ts-string">&quot;localhost&quot;</span>
    <span class="ts-string">port</span>: <span class="ts-number">5432</span>
    <span class="ts-string">name</span>: <span class="ts-string">&quot;reviewboard&quot;</span>
    <span class="ts-string">username</span>: <span class="ts-string">&quot;dbuser&quot;</span>
    <span class="ts-string">password</span>: <span class="ts-string">&quot;secretpass&quot;</span>
    <span class="ts-string">ssl</span>:
      <span class="ts-string">enabled</span>: <span class="ts-boolean">true</span>
      <span class="ts-string">cert_path</span>: <span class="ts-string">&quot;/etc/ssl/certs/db.crt&quot;</span>
      <span class="ts-string">key_path</span>: <span class="ts-string">&quot;/etc/ssl/private/db.key&quot;</span>
    <span class="ts-string">pool</span>:
      <span class="ts-string">min_size</span>: <span class="ts-number">5</span>
      <span class="ts-string">max_size</span>: <span class="ts-number">20</span>
      <span class="ts-string">idle_timeout</span>: <span class="ts-number">300</span>

<span class="ts-comment"># Server configuration</span>
<span class="ts-string">server</span>:
  <span class="ts-comment"># Literal block scalar</span>
  <span class="ts-string">bind_address</span>: <span class="ts-string">|</span>
<span class="ts-string">    0.0.0.0</span>
  <span class="ts-string">port</span>: <span class="ts-number">8080</span>

  <span class="ts-comment"># Folded block scalar</span>
  <span class="ts-string">welcome_message</span>: <span class="ts-string">&gt;</span>
<span class="ts-string">    Welcome to ReviewBoard!</span>
<span class="ts-string">    This is a code review platform</span>
<span class="ts-string">    that helps teams collaborate effectively.</span>

  <span class="ts-comment"># Security settings</span>
  <span class="ts-string">security</span>:
    <span class="ts-string">cors</span>:
      <span class="ts-string">enabled</span>: <span class="ts-boolean">true</span>
      <span class="ts-string">origins</span>:
        - <span class="ts-string">&quot;https://example.com&quot;</span>
        - <span class="ts-string">&quot;https://app.example.com&quot;</span>
        - <span class="ts-string">&quot;http://localhost:3000&quot;</span>
    <span class="ts-string">csrf</span>:
      <span class="ts-string">enabled</span>: <span class="ts-boolean">true</span>
      <span class="ts-string">secret_key</span>: <span class="ts-string">&quot;random-secret-key-here&quot;</span>
    <span class="ts-string">rate_limiting</span>:
      <span class="ts-string">enabled</span>: <span class="ts-boolean">true</span>
      <span class="ts-string">requests_per_minute</span>: <span class="ts-number">60</span>
      <span class="ts-string">burst_limit</span>: <span class="ts-number">10</span>

<span class="ts-comment"># Microservices configuration</span>
<span class="ts-string">services</span>:
  <span class="ts-string">auth_service</span>:
    <span class="ts-comment"># Reference to default environment</span>
    <span class="ts-string">&lt;&lt;</span>: *default_env
    <span class="ts-string">host</span>: <span class="ts-string">&quot;auth.internal&quot;</span>
    <span class="ts-string">port</span>: <span class="ts-number">9001</span>

  <span class="ts-string">notification_service</span>:
    <span class="ts-string">&lt;&lt;</span>: *default_env
    <span class="ts-string">host</span>: <span class="ts-string">&quot;notifications.internal&quot;</span>
    <span class="ts-string">port</span>: <span class="ts-number">9002</span>
    <span class="ts-string">config</span>:
      <span class="ts-string">email</span>:
        <span class="ts-string">smtp_host</span>: <span class="ts-string">&quot;smtp.example.com&quot;</span>
        <span class="ts-string">smtp_port</span>: <span class="ts-number">587</span>
        <span class="ts-string">username</span>: <span class="ts-string">&quot;notifications@example.com&quot;</span>
        <span class="ts-string">use_tls</span>: <span class="ts-boolean">true</span>
      <span class="ts-string">slack</span>:
        <span class="ts-string">webhook_url</span>: <span class="ts-string">&quot;https://hooks.slack.com/services/...&quot;</span>
        <span class="ts-string">default_channel</span>: <span class="ts-string">&quot;#code-reviews&quot;</span>

<span class="ts-comment"># Development environment overrides</span>
<span class="ts-string">development</span>:
  <span class="ts-string">app</span>:
    <span class="ts-comment"># Merge with default environment and override specific values</span>
    <span class="ts-string">environment</span>:
      <span class="ts-string">&lt;&lt;</span>: *default_env
      <span class="ts-string">debug</span>: <span class="ts-boolean">true</span>
      <span class="ts-string">logging_level</span>: <span class="ts-string">&quot;debug&quot;</span>

  <span class="ts-string">database</span>:
    <span class="ts-comment"># Reference to database config and override</span>
    <span class="ts-string">&lt;&lt;</span>: *db_config
    <span class="ts-string">host</span>: <span class="ts-string">&quot;localhost&quot;</span>
    <span class="ts-string">name</span>: <span class="ts-string">&quot;reviewboard_dev&quot;</span>

<span class="ts-comment"># Production environment</span>
<span class="ts-string">production</span>:
  <span class="ts-string">app</span>:
    <span class="ts-string">environment</span>:
      <span class="ts-string">&lt;&lt;</span>: *default_env
      <span class="ts-string">debug</span>: <span class="ts-boolean">false</span>
      <span class="ts-string">logging_level</span>: <span class="ts-string">&quot;warn&quot;</span>
      <span class="ts-string">max_connections</span>: <span class="ts-number">500</span>

  <span class="ts-string">database</span>:
    <span class="ts-string">&lt;&lt;</span>: *db_config
    <span class="ts-string">host</span>: <span class="ts-string">&quot;prod-db.example.com&quot;</span>
    <span class="ts-string">port</span>: <span class="ts-number">5432</span>

  <span class="ts-comment"># Load balancer configuration</span>
  <span class="ts-string">load_balancer</span>:
    <span class="ts-string">enabled</span>: <span class="ts-boolean">true</span>
    <span class="ts-string">algorithm</span>: <span class="ts-string">&quot;round_robin&quot;</span>
    <span class="ts-string">health_check</span>:
      <span class="ts-string">path</span>: <span class="ts-string">&quot;/health&quot;</span>
      <span class="ts-string">interval</span>: <span class="ts-number">30</span>
      <span class="ts-string">timeout</span>: <span class="ts-number">5</span>

<span class="ts-comment"># Feature flags</span>
<span class="ts-string">features</span>:
  <span class="ts-string">new_ui</span>: <span class="ts-boolean">true</span>
  <span class="ts-string">advanced_search</span>: <span class="ts-boolean">false</span>
  <span class="ts-string">real_time_notifications</span>: <span class="ts-boolean">true</span>
  <span class="ts-string">dark_mode</span>: <span class="ts-boolean">true</span>
  <span class="ts-string">two_factor_auth</span>: <span class="ts-boolean">true</span>

<span class="ts-comment"># Scheduled tasks</span>
<span class="ts-string">tasks</span>:
  - <span class="ts-string">name</span>: <span class="ts-string">&quot;cleanup_old_reviews&quot;</span>
    <span class="ts-string">schedule</span>: <span class="ts-string">&quot;0 2 * * *&quot;</span>  <span class="ts-comment"># Daily at 2 AM</span>
    <span class="ts-string">command</span>: <span class="ts-string">&quot;python manage.py cleanup_reviews&quot;</span>
    <span class="ts-string">enabled</span>: <span class="ts-boolean">true</span>

  - <span class="ts-string">name</span>: <span class="ts-string">&quot;send_digest_emails&quot;</span>
    <span class="ts-string">schedule</span>: <span class="ts-string">&quot;0 9 * * 1&quot;</span>  <span class="ts-comment"># Monday at 9 AM</span>
    <span class="ts-string">command</span>: <span class="ts-string">&quot;python manage.py send_digest&quot;</span>
    <span class="ts-string">enabled</span>: <span class="ts-boolean">true</span>
    <span class="ts-string">timeout</span>: <span class="ts-number">600</span>

  - <span class="ts-string">name</span>: <span class="ts-string">&quot;backup_database&quot;</span>
    <span class="ts-string">schedule</span>: <span class="ts-string">&quot;0 3 * * 0&quot;</span>  <span class="ts-comment"># Sunday at 3 AM</span>
    <span class="ts-string">command</span>: <span class="ts-string">&quot;pg_dump reviewboard &gt; backup.sql&quot;</span>
    <span class="ts-string">enabled</span>: <span class="ts-boolean">true</span>

<span class="ts-comment"># User roles and permissions</span>
<span class="ts-string">roles</span>:
  <span class="ts-string">admin</span>:
    <span class="ts-string">permissions</span>:
      - <span class="ts-string">&quot;create_repository&quot;</span>
      - <span class="ts-string">&quot;delete_repository&quot;</span>
      - <span class="ts-string">&quot;manage_users&quot;</span>
      - <span class="ts-string">&quot;view_admin_panel&quot;</span>
      - <span class="ts-string">&quot;manage_extensions&quot;</span>
    <span class="ts-string">description</span>: <span class="ts-string">&quot;Full system administrator&quot;</span>

  <span class="ts-string">moderator</span>:
    <span class="ts-string">permissions</span>:
      - <span class="ts-string">&quot;moderate_reviews&quot;</span>
      - <span class="ts-string">&quot;close_review_requests&quot;</span>
      - <span class="ts-string">&quot;edit_any_review&quot;</span>
    <span class="ts-string">description</span>: <span class="ts-string">&quot;Review moderator&quot;</span>

  <span class="ts-string">user</span>:
    <span class="ts-string">permissions</span>:
      - <span class="ts-string">&quot;create_review_request&quot;</span>
      - <span class="ts-string">&quot;submit_review&quot;</span>
      - <span class="ts-string">&quot;edit_own_review&quot;</span>
    <span class="ts-string">description</span>: <span class="ts-string">&quot;Standard user&quot;</span>

<span class="ts-comment"># API configuration</span>
<span class="ts-string">api</span>:
  <span class="ts-string">version</span>: <span class="ts-string">&quot;v1&quot;</span>
  <span class="ts-string">base_url</span>: <span class="ts-string">&quot;/api&quot;</span>

  <span class="ts-comment"># Rate limiting per endpoint</span>
  <span class="ts-string">endpoints</span>:
    <span class="ts-string">&quot;/reviews&quot;</span>:
      <span class="ts-string">rate_limit</span>: <span class="ts-number">100</span>
      <span class="ts-string">methods</span>: [<span class="ts-string">&quot;GET&quot;</span>, <span class="ts-string">&quot;POST&quot;</span>, <span class="ts-string">&quot;PUT&quot;</span>]

    <span class="ts-string">&quot;/repositories&quot;</span>:
      <span class="ts-string">rate_limit</span>: <span class="ts-number">50</span>
      <span class="ts-string">methods</span>: [<span class="ts-string">&quot;GET&quot;</span>, <span class="ts-string">&quot;POST&quot;</span>]
      <span class="ts-string">admin_only</span>: <span class="ts-boolean">true</span>

    <span class="ts-string">&quot;/users&quot;</span>:
      <span class="ts-string">rate_limit</span>: <span class="ts-number">200</span>
      <span class="ts-string">methods</span>: [<span class="ts-string">&quot;GET&quot;</span>]

<span class="ts-comment"># Monitoring and metrics</span>
<span class="ts-string">monitoring</span>:
  <span class="ts-string">enabled</span>: <span class="ts-boolean">true</span>

  <span class="ts-string">metrics</span>:
    - <span class="ts-string">name</span>: <span class="ts-string">&quot;request_duration&quot;</span>
      <span class="ts-string">type</span>: <span class="ts-string">&quot;histogram&quot;</span>
      <span class="ts-string">buckets</span>: [<span class="ts-number">0.1</span>, <span class="ts-number">0.25</span>, <span class="ts-number">0.5</span>, <span class="ts-number">1.0</span>, <span class="ts-number">2.5</span>, <span class="ts-number">5.0</span>, <span class="ts-number">10.0</span>]

    - <span class="ts-string">name</span>: <span class="ts-string">&quot;active_users&quot;</span>
      <span class="ts-string">type</span>: <span class="ts-string">&quot;gauge&quot;</span>

    - <span class="ts-string">name</span>: <span class="ts-string">&quot;review_requests_total&quot;</span>
      <span class="ts-string">type</span>: <span class="ts-string">&quot;counter&quot;</span>

  <span class="ts-string">alerts</span>:
    <span class="ts-string">high_error_rate</span>:
      <span class="ts-string">condition</span>: <span class="ts-string">&quot;error_rate &gt; 0.05&quot;</span>
      <span class="ts-string">duration</span>: <span class="ts-string">&quot;5m&quot;</span>
      <span class="ts-string">notification</span>: <span class="ts-string">&quot;slack&quot;</span>

    <span class="ts-string">high_response_time</span>:
      <span class="ts-string">condition</span>: <span class="ts-string">&quot;response_time_p95 &gt; 2s&quot;</span>
      <span class="ts-string">duration</span>: <span class="ts-string">&quot;3m&quot;</span>
      <span class="ts-string">notification</span>: <span class="ts-string">&quot;email&quot;</span>

<span class="ts-comment"># Integration settings</span>
<span class="ts-string">integrations</span>:
  <span class="ts-string">github</span>:
    <span class="ts-string">enabled</span>: <span class="ts-boolean">true</span>
    <span class="ts-string">app_id</span>: <span class="ts-number">12345</span>
    <span class="ts-string">webhook_secret</span>: <span class="ts-string">&quot;github_webhook_secret&quot;</span>

  <span class="ts-string">gitlab</span>:
    <span class="ts-string">enabled</span>: <span class="ts-boolean">false</span>
    <span class="ts-string">url</span>: <span class="ts-string">&quot;https://gitlab.example.com&quot;</span>
    <span class="ts-string">token</span>: <span class="ts-string">&quot;gitlab_access_token&quot;</span>

  <span class="ts-string">jira</span>:
    <span class="ts-string">enabled</span>: <span class="ts-boolean">true</span>
    <span class="ts-string">url</span>: <span class="ts-string">&quot;https://example.com&quot;</span>
    <span class="ts-string">username</span>: <span class="ts-string">&quot;api@example.com&quot;</span>
    <span class="ts-string">api_token</span>: <span class="ts-string">&quot;jira_api_token&quot;</span>

<span class="ts-comment"># Complex data structures</span>
<span class="ts-string">test_data</span>:
  <span class="ts-string">users</span>:
    - <span class="ts-string">name</span>: <span class="ts-string">&quot;Alice Johnson&quot;</span>
      <span class="ts-string">email</span>: <span class="ts-string">&quot;alice@example.com&quot;</span>
      <span class="ts-string">roles</span>: [<span class="ts-string">&quot;admin&quot;</span>, <span class="ts-string">&quot;user&quot;</span>]
      <span class="ts-string">preferences</span>:
        <span class="ts-string">theme</span>: <span class="ts-string">&quot;dark&quot;</span>
        <span class="ts-string">notifications</span>: <span class="ts-boolean">true</span>
        <span class="ts-string">language</span>: <span class="ts-string">&quot;en&quot;</span>

    - <span class="ts-string">name</span>: <span class="ts-string">&quot;Bob Smith&quot;</span>
      <span class="ts-string">email</span>: <span class="ts-string">&quot;bob@example.com&quot;</span>
      <span class="ts-string">roles</span>: [<span class="ts-string">&quot;user&quot;</span>]
      <span class="ts-string">preferences</span>:
        <span class="ts-string">theme</span>: <span class="ts-string">&quot;light&quot;</span>
        <span class="ts-string">notifications</span>: <span class="ts-boolean">false</span>
        <span class="ts-string">language</span>: <span class="ts-string">&quot;es&quot;</span>

  <span class="ts-comment"># Multi-dimensional data</span>
  <span class="ts-string">performance_matrix</span>:
    - [<span class="ts-number">1.2</span>, <span class="ts-number">1.5</span>, <span class="ts-number">1.8</span>, <span class="ts-number">2.1</span>]
    - [<span class="ts-number">1.1</span>, <span class="ts-number">1.3</span>, <span class="ts-number">1.6</span>, <span class="ts-number">1.9</span>]
    - [<span class="ts-number">1.0</span>, <span class="ts-number">1.2</span>, <span class="ts-number">1.4</span>, <span class="ts-number">1.7</span>]

<span class="ts-comment"># Special YAML values</span>
<span class="ts-string">special_values</span>:
  <span class="ts-string">null_value</span>: <span class="ts-constant-builtin">null</span>
  <span class="ts-string">empty_string</span>: <span class="ts-string">&quot;&quot;</span>
  <span class="ts-string">boolean_true</span>: <span class="ts-boolean">true</span>
  <span class="ts-string">boolean_false</span>: <span class="ts-boolean">false</span>
  <span class="ts-string">integer</span>: <span class="ts-number">42</span>
  <span class="ts-string">float</span>: <span class="ts-number">3.14159</span>
  <span class="ts-string">scientific</span>: <span class="ts-number">1.2e-3</span>
  <span class="ts-string">octal</span>: <span class="ts-number">0o755</span>
  <span class="ts-string">hexadecimal</span>: <span class="ts-number">0xFF</span>
  <span class="ts-string">infinity</span>: <span class="ts-number">.inf</span>
  <span class="ts-string">not_a_number</span>: <span class="ts-number">.nan</span>
