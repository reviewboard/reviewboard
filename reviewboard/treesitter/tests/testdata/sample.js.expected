<span class="ts-comment"> */</span>
<span class="ts-keyword">function</span> <span class="ts-function"><span class="ts-variable">processNumbers</span></span>(<span class="ts-variable">numbers</span>) {
    <span class="ts-keyword">if</span> (<span class="ts-operator">!</span><span class="ts-type-builtin"><span class="ts-variable">Array</span></span>.<span class="ts-function-method-call"><span class="ts-variable">isArray</span></span>(<span class="ts-variable">numbers</span>) <span class="ts-operator">||</span> <span class="ts-variable">numbers</span>.<span class="ts-variable">length</span> <span class="ts-operator">===</span> <span class="ts-number">0</span>) {
        <span class="ts-keyword">return</span> { <span class="ts-variable">sum</span>: <span class="ts-number">0</span>, <span class="ts-variable">average</span>: <span class="ts-number">0</span>, <span class="ts-variable">max</span>: <span class="ts-number">0</span>, <span class="ts-variable">min</span>: <span class="ts-number">0</span> };
    }

    <span class="ts-keyword">const</span> <span class="ts-variable">sum</span> <span class="ts-operator">=</span> <span class="ts-variable">numbers</span>.<span class="ts-function-method-call"><span class="ts-variable">reduce</span></span>((<span class="ts-variable">acc</span>, <span class="ts-variable">num</span>) <span class="ts-operator">=&gt;</span> <span class="ts-variable">acc</span> <span class="ts-operator">+</span> <span class="ts-variable">num</span>, <span class="ts-number">0</span>);
    <span class="ts-keyword">const</span> <span class="ts-variable">average</span> <span class="ts-operator">=</span> <span class="ts-variable">sum</span> <span class="ts-operator">/</span> <span class="ts-variable">numbers</span>.<span class="ts-variable">length</span>;
