        <span class="ts-variable-builtin">this</span>.<span class="ts-variable">basePath</span> <span class="ts-operator">=</span> <span class="ts-variable">basePath</span>;
        <span class="ts-variable-builtin">this</span>.<span class="ts-variable">cache</span> <span class="ts-operator">=</span> <span class="ts-keyword">new</span> <span class="ts-type-builtin"><span class="ts-constructor"><span class="ts-variable">Map</span></span></span>();
