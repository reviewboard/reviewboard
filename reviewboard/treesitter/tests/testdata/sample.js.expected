<span class="ts-keyword">const</span> <span class="ts-variable">fs</span> <span class="ts-operator">=</span> <span class="ts-function-builtin"><span class="ts-function-call"><span class="ts-variable">require</span></span></span>(<span class="ts-string">&#39;fs&#39;</span>);
