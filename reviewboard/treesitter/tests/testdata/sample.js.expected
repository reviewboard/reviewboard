            <span class="ts-variable-builtin">this</span>.<span class="ts-variable">cache</span>.<span class="ts-function-method-call"><span class="ts-variable">set</span></span>(<span class="ts-variable">fullPath</span>, <span class="ts-variable">content</span>);
