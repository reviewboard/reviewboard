<span class="ts-comment">/**</span>
<span class="ts-comment"> * Main function to demonstrate functionality.</span>
<span class="ts-comment"> */</span>
<span class="ts-keyword">async</span> <span class="ts-keyword">function</span> <span class="ts-function"><span class="ts-variable">main</span></span>() {
    <span class="ts-keyword">const</span> <span class="ts-variable">fileUtil</span> <span class="ts-operator">=</span> <span class="ts-keyword">new</span> <span class="ts-constructor"><span class="ts-variable">FileUtil</span></span>(<span class="ts-string">&#39;./data&#39;</span>);
    <span class="ts-keyword">const</span> <span class="ts-variable">numbers</span> <span class="ts-operator">=</span> [<span class="ts-number">1</span>, <span class="ts-number">2</span>, <span class="ts-number">3</span>, <span class="ts-number">4</span>, <span class="ts-number">5</span>, <span class="ts-number">10</span>, <span class="ts-number">15</span>, <span class="ts-number">20</span>];

