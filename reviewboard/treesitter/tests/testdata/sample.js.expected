<span class="ts-comment">/**</span>
<span class="ts-comment"> * Process an array of numbers.</span>
<span class="ts-comment"> * <span class="ts-keyword">@param</span> {number[]} <span class="ts-variable">numbers</span> - Array of numbers to process.</span>
