        <span class="ts-comment">// Process numbers</span>
        <span class="ts-keyword">const</span> <span class="ts-variable">stats</span> <span class="ts-operator">=</span> <span class="ts-function-call"><span class="ts-variable">processNumbers</span></span>(<span class="ts-variable">numbers</span>);
        <span class="ts-variable-builtin"><span class="ts-variable">console</span></span>.<span class="ts-function-method-call"><span class="ts-variable">log</span></span>(<span class="ts-string">&#39;Number statistics:&#39;</span>, <span class="ts-variable">stats</span>);

        <span class="ts-comment">// Write results to file</span>
        <span class="ts-keyword">const</span> <span class="ts-variable">output</span> <span class="ts-operator">=</span> <span class="ts-constant"><span class="ts-variable">JSON</span></span>.<span class="ts-function-method-call"><span class="ts-variable">stringify</span></span>(<span class="ts-variable">stats</span>, <span class="ts-constant-builtin">null</span>, <span class="ts-number">2</span>);
