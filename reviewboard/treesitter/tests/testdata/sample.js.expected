    <span class="ts-comment">/**</span>
<span class="ts-comment">     * Read a file asynchronously.</span>
<span class="ts-comment">     * <span class="ts-keyword">@param</span> {string} <span class="ts-variable">filename</span> - The name of the file to read.</span>
<span class="ts-comment">     * <span class="ts-keyword">@returns</span> {Promise&lt;string&gt;} The file contents.</span>
<span class="ts-comment">     */</span>
    <span class="ts-keyword">async</span> <span class="ts-function"><span class="ts-variable">readFile</span></span>(<span class="ts-variable">filename</span>) {
