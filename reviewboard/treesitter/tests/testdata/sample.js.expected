        <span class="ts-variable-builtin"><span class="ts-variable">console</span></span>.<span class="ts-function-method-call"><span class="ts-variable">log</span></span>(<span class="ts-string">&#39;Results written to stats.json&#39;</span>);

        <span class="ts-comment">// Read config if it exists</span>
        <span class="ts-keyword">try</span> {
            <span class="ts-keyword">const</span> <span class="ts-variable">config</span> <span class="ts-operator">=</span> <span class="ts-keyword">await</span> <span class="ts-variable">fileUtil</span>.<span class="ts-function-method-call"><span class="ts-variable">readFile</span></span>(<span class="ts-constant"><span class="ts-variable">CONFIG_FILE</span></span>);
            <span class="ts-variable-builtin"><span class="ts-variable">console</span></span>.<span class="ts-function-method-call"><span class="ts-variable">log</span></span>(<span class="ts-string">&#39;Config loaded:&#39;</span>, <span class="ts-constant"><span class="ts-variable">JSON</span></span>.<span class="ts-function-method-call"><span class="ts-variable">parse</span></span>(<span class="ts-variable">config</span>));
